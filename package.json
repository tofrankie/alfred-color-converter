{
  "name": "alfred-color-converter",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.0",
  "description": "💻 An Alfred workflow for color conversion",
  "author": {
    "name": "Frankie",
    "email": "1426203851@qq.com",
    "url": "https://github.com/tofrankie"
  },
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/alfred-color-converter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/alfred-color-converter.git"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/alfred-color-converter/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "alfred",
    "workflow",
    "color",
    "rgb",
    "hex",
    "rgba",
    "convert",
    "converter"
  ],
  "bin": {
    "alfred-color-converter-import": "bin/install.sh"
  },
  "files": [
    "CHANGELOG.md",
    "alfred-color-converter.alfredworkflow",
    "bin"
  ],
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "prepublish": "run-s lint build",
    "build": "run-s build:js build:alfred",
    "build:js": "rollup -c",
    "build:alfred": "node scripts/build.js",
    "lint": "run-s eslint:fix prettier:fix",
    "eslint:fix": "eslint . --fix --cache",
    "prettier:fix": "prettier './**/*.{json,js}' --write --cache"
  },
  "dependencies": {
    "color-convert": "^3.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tofrankie/eslint": "^0.2.1",
    "@tofrankie/prettier": "^0.2.0",
    "adm-zip": "^0.5.17",
    "eslint": "^10.2.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.0.3",
    "rollup": "^4.60.1"
  }
}
